{
  "name": "panw-ae-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "pnpm run clean && pnpm run build:packages && pnpm run build:demo",
    "build:packages": "pnpm --filter @ds/colors run build && pnpm --filter @ds/themes run build && pnpm --filter @ds/type run build && pnpm --filter @ds/styles run build",
    "build:demo": "mkdir -p dist && sass demo/styles.scss dist/demo.css --load-path=node_modules --style=expanded --no-source-map",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "serve": "python3 -m http.server 4173",
    "storybook": "node ../scripts/storybook-prestart.mjs 6011 && storybook dev -p 6011 --ci",
    "storybook:port-check": "node ../scripts/storybook-prestart.mjs 6011",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-actions": "^8.6.18",
    "@storybook/addon-docs": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test-runner": "^0.24.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.9",
    "eslint": "^10.3.0",
    "jsdom": "^26.1.0",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass": "^1.99.0",
    "storybook": "^8.6.18",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@ds/accordion": "workspace:*",
    "@ds/breadcrumbs": "workspace:*",
    "@ds/button": "workspace:*",
    "@ds/cell-contents": "workspace:*",
    "@ds/cells-standard": "workspace:*",
    "@ds/checkbox": "workspace:*",
    "@ds/chips": "workspace:*",
    "@ds/colors": "workspace:*",
    "@ds/content-switcher": "workspace:*",
    "@ds/dropdown": "workspace:*",
    "@ds/filter": "workspace:*",
    "@ds/flyout": "workspace:*",
    "@ds/header": "workspace:*",
    "@ds/icons": "workspace:*",
    "@ds/inline-notification": "workspace:*",
    "@ds/link": "workspace:*",
    "@ds/multi-select": "workspace:*",
    "@ds/number-input": "workspace:*",
    "@ds/pagination": "workspace:*",
    "@ds/popover": "workspace:*",
    "@ds/progress-step": "workspace:*",
    "@ds/radio-button": "workspace:*",
    "@ds/search": "workspace:*",
    "@ds/styles": "workspace:*",
    "@ds/tabs": "workspace:*",
    "@ds/tags": "workspace:*",
    "@ds/text-entry": "workspace:*",
    "@ds/themes": "workspace:*",
    "@ds/toggle": "workspace:*",
    "@ds/tooltip": "workspace:*",
    "@ds/type": "workspace:*",
    "classnames": "^2.5.1",
    "prop-types": "^15.8.1"
  }
}
