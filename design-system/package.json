{
  "name": "panw-ae-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && npm run build:packages && npm run build:demo",
    "build:packages": "npm run build -w @ds/colors && npm run build -w @ds/themes && npm run build -w @ds/type && npm run build -w @ds/styles",
    "build:demo": "mkdir -p dist && sass demo/styles.scss dist/demo.css --load-path=node_modules --style=expanded --no-source-map",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "serve": "python3 -m http.server 4173",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-actions": "^8.6.18",
    "@storybook/addon-docs": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.9",
    "eslint": "^10.3.0",
    "jsdom": "^26.1.0",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass": "^1.99.0",
    "storybook": "^8.6.18",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "prop-types": "^15.8.1"
  }
}
