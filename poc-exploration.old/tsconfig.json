{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@ds/styles/css/styles.css": ["../design-system/packages/styles/css/styles.css"],
      "@ds/accordion":           ["../design-system/packages/accordion"],
      "@ds/breadcrumbs":         ["../design-system/packages/breadcrumbs"],
      "@ds/button":              ["../design-system/packages/button"],
      "@ds/cell-contents":       ["../design-system/packages/cell-contents"],
      "@ds/cells-standard":      ["../design-system/packages/cells-standard"],
      "@ds/checkbox":            ["../design-system/packages/checkbox"],
      "@ds/chips":               ["../design-system/packages/chips"],
      "@ds/content-switcher":    ["../design-system/packages/content-switcher"],
      "@ds/dropdown":            ["../design-system/packages/dropdown"],
      "@ds/flyout":              ["../design-system/packages/flyout"],
      "@ds/header":              ["../design-system/packages/header"],
      "@ds/inline-notification": ["../design-system/packages/inline-notification"],
      "@ds/link":                ["../design-system/packages/link"],
      "@ds/multi-select":        ["../design-system/packages/multi-select"],
      "@ds/number-input":        ["../design-system/packages/number-input"],
      "@ds/pagination":          ["../design-system/packages/pagination"],
      "@ds/popover":             ["../design-system/packages/popover"],
      "@ds/progress-step":       ["../design-system/packages/progress-step"],
      "@ds/radio-button":        ["../design-system/packages/radio-button"],
      "@ds/search":              ["../design-system/packages/search"],
      "@ds/tabs":                ["../design-system/packages/tabs"],
      "@ds/tags":                ["../design-system/packages/tags"],
      "@ds/text-entry":          ["../design-system/packages/text-entry"],
      "@ds/toggle":              ["../design-system/packages/toggle"],
      "@ds/tooltip":             ["../design-system/packages/tooltip"],
      "@ds/colors":              ["../design-system/packages/colors"],
      "@ds/themes":              ["../design-system/packages/themes"],
      "@ds/type":                ["../design-system/packages/type"]
    }
  },
  "include": ["src"],
  "exclude": ["../design-system"]
}
